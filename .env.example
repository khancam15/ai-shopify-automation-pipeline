# Copy to .env and fill with your own credentials.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
SERPER_API_KEY=your_serper_api_key_here

# ── Shopify Admin API credentials ─────────────────────────────────────────────
# Run once (💻 HOST): python scripts/shopify_setup.py
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_your_admin_api_access_token
SHOPIFY_API_VERSION=2024-01
SHOPIFY_VENDOR=Benjaire LLC

# ── Canva Connect API credentials ─────────────────────────────────────────────
# Run once (💻 HOST): python scripts/canva_oauth.py
# That script opens your browser, completes OAuth, and fills these in for you.
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
CANVA_ACCESS_TOKEN=
CANVA_REFRESH_TOKEN=

# Canva MCP OAuth token — used by Phase 3 (canva_image_generator.py)
# Populated automatically after running canva_oauth.py.
# To set manually: visit the OAuth URL printed by canva_image_generator.py,
# authorise, copy the Bearer token, and paste here as: CANVA_MCP_TOKEN=Bearer <token>
CANVA_MCP_TOKEN=

# ── Publishing cadence ────────────────────────────────────────────────────────
# Max Shopify products published per calendar week (Mon–Sun UTC).
# Pipeline switches to maintain mode (SEO-only) once this is reached.
# Recommended: 3–7 for a new store, up to 20 for an established one.
WEEKLY_PUBLISH_LIMIT=5

# Minimum hours between consecutive Shopify publishes.
# Prevents burst-publishing — spreads listings naturally across the week.
# 24 = one listing per day (recommended). Set lower (e.g. 12) to publish faster.
PUBLISH_COOLDOWN_HOURS=24

# Disable CrewAI telemetry/tracing (keeps logs clean on VPS)
CREWAI_TRACING_ENABLED=false

# Daily email digest — design brief sent every morning
# Generate app password at: myaccount.google.com/apppasswords
# (requires Gmail 2FA to be enabled)
EMAIL_TO=your_email@gmail.com
EMAIL_FROM=your_gmail@gmail.com
EMAIL_SMTP_PASS=your_gmail_app_password
